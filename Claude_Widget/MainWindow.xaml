<Window x:Class="Claude_Widget.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		Title="Claude Widget"
		Icon="pack://application:,,,/Assets/app.ico"
		Width="340" Height="332"
		WindowStyle="None"
		AllowsTransparency="True"
		Background="Transparent"
		Topmost="True"
		ShowInTaskbar="False"
		ResizeMode="NoResize"
		MouseLeftButtonDown="Window_MouseLeftButtonDown">

	<Window.ContextMenu>
		<ContextMenu x:Name="WidgetContextMenu">
			<MenuItem Header="세션 대시보드 보기" Click="ShowHud_Click"/>
			<MenuItem Header="오늘의 기록 보기" Click="ShowStats_Click"/>
			<Separator/>
			<MenuItem Header="테마">
				<MenuItem Header="클로드 (주황)" Tag="Claude" Click="ChangeTheme_Click"/>
				<MenuItem Header="바다 (파랑)" Tag="Ocean" Click="ChangeTheme_Click"/>
				<MenuItem Header="숲 (초록)" Tag="Forest" Click="ChangeTheme_Click"/>
				<MenuItem Header="포도 (보라)" Tag="Grape" Click="ChangeTheme_Click"/>
				<MenuItem Header="자정 (다크)" Tag="Midnight" Click="ChangeTheme_Click"/>
			</MenuItem>
			<MenuItem Header="크기">
				<MenuItem Header="작게" Tag="0.7" Click="ChangeSize_Click"/>
				<MenuItem Header="보통" Tag="1.0" Click="ChangeSize_Click"/>
				<MenuItem Header="크게" Tag="1.4" Click="ChangeSize_Click"/>
			</MenuItem>
			<Separator/>
			<MenuItem x:Name="MenuSpeech" Header="말풍선 표시" IsCheckable="True" IsChecked="True" Click="ToggleSpeech_Click"/>
			<MenuItem x:Name="MenuTopmost" Header="항상 위에 표시" IsCheckable="True" IsChecked="True" Click="ToggleTopmost_Click"/>
			<MenuItem x:Name="MenuStartup" Header="Windows 시작 시 실행" IsCheckable="True" Click="ToggleStartup_Click"/>
			<MenuItem x:Name="MenuAutoUpdate" Header="자동 업데이트 확인" IsCheckable="True" IsChecked="True" Click="ToggleAutoUpdate_Click"/>
			<MenuItem x:Name="MenuCliHook" Header="Claude CLI 알림 연동" IsCheckable="True" Click="ToggleCliHook_Click"
					  ToolTip="Claude Code의 알림·작업완료 메시지를 말풍선으로 표시합니다"/>
			<MenuItem x:Name="MenuToolAwareness" Header="작업 상세 표시 (툴 인식)" IsCheckable="True" IsChecked="True" Click="ToggleToolAwareness_Click"
					  ToolTip="Claude가 어떤 작업(파일 읽기·명령 실행 등)을 하는지 아이콘으로 표시합니다"/>
			<Separator/>
			<MenuItem Header="업데이트 확인" Click="CheckUpdate_Click"/>
			<MenuItem Header="정보" Click="ShowAbout_Click"/>
			<Separator/>
			<MenuItem Header="종료" Click="Exit_Click"/>
		</ContextMenu>
	</Window.ContextMenu>

	<Window.Resources>
		<QuadraticEase x:Key="EaseInOut" EasingMode="EaseInOut"/>

		<!-- Themeable brushes (recolored in code by the selected theme).
			 Body uses a radial gradient for a soft 3D shell look. -->
		<RadialGradientBrush x:Key="BodyBrush" GradientOrigin="0.4,0.3" Center="0.5,0.5" RadiusX="0.78" RadiusY="0.74">
			<GradientStop Color="#E8906F" Offset="0"/>
			<GradientStop Color="#C9603F" Offset="1"/>
		</RadialGradientBrush>
		<SolidColorBrush x:Key="BodyStrokeBrush" Color="#B15038"/>
		<SolidColorBrush x:Key="LimbBrush" Color="#CE6A4C"/>
		<SolidColorBrush x:Key="LimbStrokeBrush" Color="#A9502F"/>

		<!-- Breathing animation (always running) -->
		<Storyboard x:Key="BreathingAnimation" RepeatBehavior="Forever">
			<DoubleAnimation
				Storyboard.TargetName="BodyTransform"
				Storyboard.TargetProperty="ScaleY"
				From="1.0" To="1.03" Duration="0:0:1.2"
				AutoReverse="True"
				EasingFunction="{StaticResource EaseInOut}"/>
			<DoubleAnimation
				Storyboard.TargetName="ShadowTransform"
				Storyboard.TargetProperty="ScaleX"
				From="1.0" To="0.95" Duration="0:0:1.2"
				AutoReverse="True"
				EasingFunction="{StaticResource EaseInOut}"/>
		</Storyboard>

		<!-- Blink animation -->
		<Storyboard x:Key="BlinkAnimation">
			<DoubleAnimation
				Storyboard.TargetName="LeftEyeGroup"
				Storyboard.TargetProperty="Opacity"
				From="1" To="0" Duration="0:0:0.08"
				AutoReverse="True"/>
			<DoubleAnimation
				Storyboard.TargetName="RightEyeGroup"
				Storyboard.TargetProperty="Opacity"
				From="1" To="0" Duration="0:0:0.08"
				AutoReverse="True"/>
			<DoubleAnimation
				Storyboard.TargetName="LeftEyeClosed"
				Storyboard.TargetProperty="Opacity"
				From="0" To="1" Duration="0:0:0.08"
				AutoReverse="True"/>
			<DoubleAnimation
				Storyboard.TargetName="RightEyeClosed"
				Storyboard.TargetProperty="Opacity"
				From="0" To="1" Duration="0:0:0.08"
				AutoReverse="True"/>
		</Storyboard>

		<!-- Look left animation -->
		<Storyboard x:Key="LookLeftAnimation">
			<DoubleAnimation
				Storyboard.TargetName="LeftPupilTranslate"
				Storyboard.TargetProperty="X"
				From="0" To="-3" Duration="0:0:0.4"
				AutoReverse="True"
				EasingFunction="{StaticResource EaseInOut}"/>
			<DoubleAnimation
				Storyboard.TargetName="RightPupilTranslate"
				Storyboard.TargetProperty="X"
				From="0" To="-3" Duration="0:0:0.4"
				AutoReverse="True"
				EasingFunction="{StaticResource EaseInOut}"/>
		</Storyboard>

		<!-- Look right animation -->
		<Storyboard x:Key="LookRightAnimation">
			<DoubleAnimation
				Storyboard.TargetName="LeftPupilTranslate"
				Storyboard.TargetProperty="X"
				From="0" To="3" Duration="0:0:0.4"
				AutoReverse="True"
				EasingFunction="{StaticResource EaseInOut}"/>
			<DoubleAnimation
				Storyboard.TargetName="RightPupilTranslate"
				Storyboard.TargetProperty="X"
				From="0" To="3" Duration="0:0:0.4"
				AutoReverse="True"
				EasingFunction="{StaticResource EaseInOut}"/>
		</Storyboard>

		<!-- Idle bounce -->
		<Storyboard x:Key="IdleBounceAnimation">
			<DoubleAnimation
				Storyboard.TargetName="CharacterTranslate"
				Storyboard.TargetProperty="Y"
				From="0" To="-6" Duration="0:0:0.25"
				AutoReverse="True"
				EasingFunction="{StaticResource EaseInOut}"/>
		</Storyboard>

		<!-- Typing animation: arms slam up/down alternating -->
		<Storyboard x:Key="TypingAnimation" RepeatBehavior="Forever">
			<!-- Left arm: big vertical slam -->
			<DoubleAnimation
				Storyboard.TargetName="LeftArmTypingTranslate"
				Storyboard.TargetProperty="Y"
				From="0" To="-8" Duration="0:0:0.15"
				AutoReverse="True"/>
			<!-- Right arm: offset timing for alternating feel -->
			<DoubleAnimation
				Storyboard.TargetName="RightArmTypingTranslate"
				Storyboard.TargetProperty="Y"
				From="0" To="-8" Duration="0:0:0.15"
				AutoReverse="True"
				BeginTime="0:0:0.15"/>
		</Storyboard>

		<!-- Body bobbing while typing -->
		<Storyboard x:Key="TypingBodyBob" RepeatBehavior="Forever">
			<DoubleAnimation
				Storyboard.TargetName="CharacterTranslate"
				Storyboard.TargetProperty="Y"
				From="0" To="-4" Duration="0:0:0.18"
				AutoReverse="True"
				EasingFunction="{StaticResource EaseInOut}"/>
		</Storyboard>

		<!-- Eyes look down at screen while working -->
		<Storyboard x:Key="EyesLookDownAnimation">
			<DoubleAnimation
				Storyboard.TargetName="LeftPupilTranslate"
				Storyboard.TargetProperty="Y"
				To="3" Duration="0:0:0.3"
				EasingFunction="{StaticResource EaseInOut}"/>
			<DoubleAnimation
				Storyboard.TargetName="RightPupilTranslate"
				Storyboard.TargetProperty="Y"
				To="3" Duration="0:0:0.3"
				EasingFunction="{StaticResource EaseInOut}"/>
		</Storyboard>

		<!-- Eyes look back center (idle) -->
		<Storyboard x:Key="EyesLookCenterAnimation">
			<DoubleAnimation
				Storyboard.TargetName="LeftPupilTranslate"
				Storyboard.TargetProperty="Y"
				To="0" Duration="0:0:0.3"
				EasingFunction="{StaticResource EaseInOut}"/>
			<DoubleAnimation
				Storyboard.TargetName="RightPupilTranslate"
				Storyboard.TargetProperty="Y"
				To="0" Duration="0:0:0.3"
				EasingFunction="{StaticResource EaseInOut}"/>
		</Storyboard>

		<!-- Screen glow pulse -->
		<Storyboard x:Key="ScreenGlowAnimation" RepeatBehavior="Forever">
			<DoubleAnimation
				Storyboard.TargetName="ScreenGlow"
				Storyboard.TargetProperty="Opacity"
				From="0.5" To="1.0" Duration="0:0:0.6"
				AutoReverse="True"/>
		</Storyboard>

		<!-- Laptop fade in -->
		<Storyboard x:Key="LaptopFadeIn">
			<DoubleAnimation
				Storyboard.TargetName="LaptopGroup"
				Storyboard.TargetProperty="Opacity"
				From="0" To="1" Duration="0:0:0.3"/>
		</Storyboard>

		<!-- Laptop fade out -->
		<Storyboard x:Key="LaptopFadeOut">
			<DoubleAnimation
				Storyboard.TargetName="LaptopGroup"
				Storyboard.TargetProperty="Opacity"
				From="1" To="0" Duration="0:0:0.3"/>
		</Storyboard>

		<!-- Sparkle twinkle -->
		<Storyboard x:Key="SparkleAnimation" RepeatBehavior="Forever">
			<DoubleAnimation
				Storyboard.TargetName="SparkleRotate"
				Storyboard.TargetProperty="Angle"
				From="0" To="360" Duration="0:0:8"/>
			<DoubleAnimation
				Storyboard.TargetName="SparkleScale"
				Storyboard.TargetProperty="ScaleX"
				From="0.85" To="1.15" Duration="0:0:1.5"
				AutoReverse="True"/>
			<DoubleAnimation
				Storyboard.TargetName="SparkleScale"
				Storyboard.TargetProperty="ScaleY"
				From="0.85" To="1.15" Duration="0:0:1.5"
				AutoReverse="True"/>
		</Storyboard>

		<!-- Sleepy Zzz: drift up + gentle fade loop (started when the widget dozes off) -->
		<Storyboard x:Key="SleepZzzAnimation" RepeatBehavior="Forever">
			<DoubleAnimation Storyboard.TargetName="SleepZzzTranslate" Storyboard.TargetProperty="Y"
							 From="2" To="-12" Duration="0:0:2.2"/>
			<DoubleAnimation Storyboard.TargetName="SleepZzz" Storyboard.TargetProperty="Opacity"
							 From="0.25" To="1" Duration="0:0:1.1" AutoReverse="True"/>
		</Storyboard>

		<!-- Celebration: a quick scale pop of the head sparkle + hop on task completion.
		     FillBehavior=Stop so it releases the properties afterward and the perpetual
		     SparkleAnimation resumes control of the twinkle. -->
		<Storyboard x:Key="CelebrateAnimation">
			<DoubleAnimation Storyboard.TargetName="SparkleScale" Storyboard.TargetProperty="ScaleX"
							 From="1" To="1.9" Duration="0:0:0.5" AutoReverse="True" FillBehavior="Stop"
							 EasingFunction="{StaticResource BubbleEase}"/>
			<DoubleAnimation Storyboard.TargetName="SparkleScale" Storyboard.TargetProperty="ScaleY"
							 From="1" To="1.9" Duration="0:0:0.5" AutoReverse="True" FillBehavior="Stop"
							 EasingFunction="{StaticResource BubbleEase}"/>
			<DoubleAnimation Storyboard.TargetName="CharacterTranslate" Storyboard.TargetProperty="Y"
							 From="0" To="-10" Duration="0:0:0.22" AutoReverse="True" FillBehavior="Stop"
							 EasingFunction="{StaticResource EaseInOut}"/>
		</Storyboard>

		<!-- Speech bubble pop-in (scale + fade with a playful overshoot) -->
		<BackEase x:Key="BubbleEase" EasingMode="EaseOut" Amplitude="0.6"/>
		<Storyboard x:Key="BubblePopIn">
			<DoubleAnimation
				Storyboard.TargetName="SpeechBubble"
				Storyboard.TargetProperty="Opacity"
				To="1" Duration="0:0:0.18"/>
			<DoubleAnimation
				Storyboard.TargetName="BubbleScale"
				Storyboard.TargetProperty="ScaleX"
				From="0.5" To="1" Duration="0:0:0.28"
				EasingFunction="{StaticResource BubbleEase}"/>
			<DoubleAnimation
				Storyboard.TargetName="BubbleScale"
				Storyboard.TargetProperty="ScaleY"
				From="0.5" To="1" Duration="0:0:0.28"
				EasingFunction="{StaticResource BubbleEase}"/>
		</Storyboard>

		<!-- Speech bubble fade-out -->
		<Storyboard x:Key="BubbleFadeOut">
			<DoubleAnimation
				Storyboard.TargetName="SpeechBubble"
				Storyboard.TargetProperty="Opacity"
				To="0" Duration="0:0:0.25"/>
			<DoubleAnimation
				Storyboard.TargetName="BubbleScale"
				Storyboard.TargetProperty="ScaleY"
				To="0.7" Duration="0:0:0.25"/>
		</Storyboard>

		<!-- Update badge pulse (draws the eye to a pending update) -->
		<Storyboard x:Key="UpdateBadgePulse" RepeatBehavior="Forever">
			<DoubleAnimation
				Storyboard.TargetName="UpdateBadgeScale"
				Storyboard.TargetProperty="ScaleX"
				From="1" To="1.25" Duration="0:0:0.7"
				AutoReverse="True"
				EasingFunction="{StaticResource EaseInOut}"/>
			<DoubleAnimation
				Storyboard.TargetName="UpdateBadgeScale"
				Storyboard.TargetProperty="ScaleY"
				From="1" To="1.25" Duration="0:0:0.7"
				AutoReverse="True"
				EasingFunction="{StaticResource EaseInOut}"/>
		</Storyboard>

		<!-- Attention wave (rock side-to-side) — used for permission/notification alerts -->
		<Storyboard x:Key="WaveAnimation">
			<DoubleAnimationUsingKeyFrames Storyboard.TargetName="CharacterTranslate" Storyboard.TargetProperty="X">
				<EasingDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/>
				<EasingDoubleKeyFrame KeyTime="0:0:0.10" Value="7"/>
				<EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="-7"/>
				<EasingDoubleKeyFrame KeyTime="0:0:0.40" Value="5"/>
				<EasingDoubleKeyFrame KeyTime="0:0:0.55" Value="-5"/>
				<EasingDoubleKeyFrame KeyTime="0:0:0.70" Value="0"/>
			</DoubleAnimationUsingKeyFrames>
		</Storyboard>

		<!-- Activity badge pop (when the current tool changes) -->
		<Storyboard x:Key="ActivityPopIn">
			<DoubleAnimation Storyboard.TargetName="ActivityBadge" Storyboard.TargetProperty="Opacity"
							 To="1" Duration="0:0:0.15"/>
			<DoubleAnimation Storyboard.TargetName="ActivityScale" Storyboard.TargetProperty="ScaleX"
							 From="0.5" To="1" Duration="0:0:0.25" EasingFunction="{StaticResource BubbleEase}"/>
			<DoubleAnimation Storyboard.TargetName="ActivityScale" Storyboard.TargetProperty="ScaleY"
							 From="0.5" To="1" Duration="0:0:0.25" EasingFunction="{StaticResource BubbleEase}"/>
		</Storyboard>
		<Storyboard x:Key="ActivityFadeOut">
			<DoubleAnimation Storyboard.TargetName="ActivityBadge" Storyboard.TargetProperty="Opacity"
							 To="0" Duration="0:0:0.25"/>
		</Storyboard>

	</Window.Resources>

	<!-- Root: a fixed-height session-chip strip stacked above the character canvas.
	     The scale transform lives here so both the strip and character scale together;
	     the character canvas keeps its own 220x300 coordinate system unchanged. -->
	<Grid x:Name="RootGrid">
		<Grid.RenderTransform>
			<ScaleTransform x:Name="WidgetScale" ScaleX="1" ScaleY="1"/>
		</Grid.RenderTransform>
		<Grid.RowDefinitions>
			<RowDefinition Height="32"/>
			<RowDefinition Height="300"/>
		</Grid.RowDefinitions>

		<!-- ===== Session chip strip (multi-session awareness) ===== -->
		<Border x:Name="SessionStripHost" Grid.Row="0" Visibility="Collapsed"
				MaxWidth="340" ClipToBounds="True"
				HorizontalAlignment="Center" VerticalAlignment="Center">
			<StackPanel x:Name="SessionStrip" Orientation="Horizontal" HorizontalAlignment="Center"/>
		</Border>

	<!-- Character canvas keeps its own 220-wide coordinate system, centered in the wider window. -->
	<Canvas x:Name="MainCanvas" Grid.Row="1" Width="220" Height="300" HorizontalAlignment="Center">

		<!-- Entire character group for bounce (offset down/right to leave headroom for the speech bubble) -->
		<Canvas Canvas.Left="10" Canvas.Top="56">
			<Canvas.RenderTransform>
				<TranslateTransform x:Name="CharacterTranslate" X="0" Y="0"/>
			</Canvas.RenderTransform>

			<!-- Shadow -->
			<Ellipse Canvas.Left="55" Canvas.Top="188" Width="90" Height="14"
					 Fill="#33000000" RenderTransformOrigin="0.5,0.5">
				<Ellipse.RenderTransform>
					<ScaleTransform x:Name="ShadowTransform" ScaleX="1" ScaleY="1"/>
				</Ellipse.RenderTransform>
			</Ellipse>

			<!-- Body group (for breathing) -->
			<Canvas Canvas.Left="0" Canvas.Top="0" RenderTransformOrigin="0.5,1">
				<Canvas.RenderTransform>
					<ScaleTransform x:Name="BodyTransform" ScaleX="1" ScaleY="1" CenterX="100" CenterY="195"/>
				</Canvas.RenderTransform>

				<!-- ===== Antennae (behind body; tips arc above the head) ===== -->
				<Path Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="2.6"
					  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"
					  Data="M 92,78 Q 76,50 66,32 Q 60,22 54,14"/>
				<Path Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="2.6"
					  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"
					  Data="M 108,78 Q 124,50 134,32 Q 140,22 146,14"/>
				<Ellipse Canvas.Left="50" Canvas.Top="10" Width="9" Height="9"
						 Fill="{DynamicResource LimbBrush}" Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="1"/>
				<Ellipse Canvas.Left="142" Canvas.Top="10" Width="9" Height="9"
						 Fill="{DynamicResource LimbBrush}" Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="1"/>

				<!-- ===== Walking legs (behind body, peeking from the lower sides) ===== -->
				<Path Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="2.6"
					  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
					  Data="M 60,168 L 42,180  M 62,176 L 46,190  M 66,184 L 52,198"/>
				<Path Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="2.6"
					  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
					  Data="M 140,168 L 158,180  M 138,176 L 154,190  M 134,184 L 148,198"/>

				<!-- ===== Tail fan (behind body, bottom center) ===== -->
				<Ellipse Canvas.Left="72" Canvas.Top="182" Width="20" Height="24"
						 Fill="{DynamicResource LimbBrush}" Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="1"
						 RenderTransformOrigin="0.5,0">
					<Ellipse.RenderTransform>
						<RotateTransform Angle="-24"/>
					</Ellipse.RenderTransform>
				</Ellipse>
				<Ellipse Canvas.Left="108" Canvas.Top="182" Width="20" Height="24"
						 Fill="{DynamicResource LimbBrush}" Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="1"
						 RenderTransformOrigin="0.5,0">
					<Ellipse.RenderTransform>
						<RotateTransform Angle="24"/>
					</Ellipse.RenderTransform>
				</Ellipse>
				<Ellipse Canvas.Left="89" Canvas.Top="184" Width="22" Height="26"
						 Fill="{DynamicResource LimbBrush}" Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="1"/>

				<!-- ===== Main body / carapace ===== -->
				<Ellipse x:Name="BodyEllipse" Canvas.Left="40" Canvas.Top="68" Width="120" Height="128"
						 Fill="{DynamicResource BodyBrush}" Stroke="{DynamicResource BodyStrokeBrush}" StrokeThickness="1.5"/>

				<!-- Carapace ridge (subtle shell segmentation) -->
				<Path Stroke="{DynamicResource BodyStrokeBrush}" StrokeThickness="1" Opacity="0.35" Fill="Transparent"
					  Data="M 62,168 Q 100,178 138,168"/>

				<!-- Body highlight (glossy effect) -->
				<Ellipse Canvas.Left="55" Canvas.Top="78" Width="60" Height="40"
						 Opacity="0.25">
					<Ellipse.Fill>
						<RadialGradientBrush>
							<GradientStop Color="White" Offset="0"/>
							<GradientStop Color="Transparent" Offset="1"/>
						</RadialGradientBrush>
					</Ellipse.Fill>
				</Ellipse>

				<!-- ===== Left claw (pincer) — keeps the arm's typing transform ===== -->
				<Canvas x:Name="LeftArm">
					<Canvas.RenderTransform>
						<TransformGroup>
							<RotateTransform Angle="8" CenterX="28" CenterY="150"/>
							<TranslateTransform x:Name="LeftArmTypingTranslate" X="0" Y="0"/>
						</TransformGroup>
					</Canvas.RenderTransform>
					<!-- upper arm link to body -->
					<Ellipse Canvas.Left="30" Canvas.Top="146" Width="28" Height="13"
							 Fill="{DynamicResource LimbBrush}" Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="1"
							 RenderTransformOrigin="0.5,0.5">
						<Ellipse.RenderTransform>
							<RotateTransform Angle="22"/>
						</Ellipse.RenderTransform>
					</Ellipse>
					<!-- pincer palm (lower) -->
					<Ellipse Canvas.Left="2" Canvas.Top="140" Width="36" Height="28"
							 Fill="{DynamicResource LimbBrush}" Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="1"/>
					<!-- pincer finger (upper) -->
					<Ellipse Canvas.Left="8" Canvas.Top="127" Width="27" Height="19"
							 Fill="{DynamicResource LimbBrush}" Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="1"/>
					<!-- pinch seam -->
					<Path Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="1.4" Fill="Transparent"
						  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
						  Data="M 6,150 Q 18,146 32,148"/>
				</Canvas>

				<!-- ===== Right claw (pincer) — keeps the arm's typing transform ===== -->
				<Canvas x:Name="RightArm">
					<Canvas.RenderTransform>
						<TransformGroup>
							<RotateTransform Angle="-8" CenterX="172" CenterY="150"/>
							<TranslateTransform x:Name="RightArmTypingTranslate" X="0" Y="0"/>
						</TransformGroup>
					</Canvas.RenderTransform>
					<!-- upper arm link to body -->
					<Ellipse Canvas.Left="142" Canvas.Top="146" Width="28" Height="13"
							 Fill="{DynamicResource LimbBrush}" Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="1"
							 RenderTransformOrigin="0.5,0.5">
						<Ellipse.RenderTransform>
							<RotateTransform Angle="-22"/>
						</Ellipse.RenderTransform>
					</Ellipse>
					<!-- pincer palm (lower) -->
					<Ellipse Canvas.Left="162" Canvas.Top="140" Width="36" Height="28"
							 Fill="{DynamicResource LimbBrush}" Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="1"/>
					<!-- pincer finger (upper) -->
					<Ellipse Canvas.Left="165" Canvas.Top="127" Width="27" Height="19"
							 Fill="{DynamicResource LimbBrush}" Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="1"/>
					<!-- pinch seam -->
					<Path Stroke="{DynamicResource LimbStrokeBrush}" StrokeThickness="1.4" Fill="Transparent"
						  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
						  Data="M 168,148 Q 182,146 194,150"/>
				</Canvas>

				<!-- Left eye group -->
				<Canvas x:Name="LeftEyeGroup" Canvas.Left="64" Canvas.Top="115">
					<!-- Eye white -->
					<Ellipse Width="22" Height="24" Fill="White" Stroke="#555" StrokeThickness="0.5"/>
					<!-- Pupil -->
					<Ellipse Canvas.Left="6" Canvas.Top="6" Width="11" Height="13" Fill="#2D2D2D">
						<Ellipse.RenderTransform>
							<TranslateTransform x:Name="LeftPupilTranslate" X="0" Y="0"/>
						</Ellipse.RenderTransform>
					</Ellipse>
					<!-- Eye highlight -->
					<Ellipse Canvas.Left="10" Canvas.Top="5" Width="5" Height="5" Fill="White"/>
				</Canvas>

				<!-- Right eye group -->
				<Canvas x:Name="RightEyeGroup" Canvas.Left="110" Canvas.Top="115">
					<!-- Eye white -->
					<Ellipse Width="22" Height="24" Fill="White" Stroke="#555" StrokeThickness="0.5"/>
					<!-- Pupil -->
					<Ellipse Canvas.Left="6" Canvas.Top="6" Width="11" Height="13" Fill="#2D2D2D">
						<Ellipse.RenderTransform>
							<TranslateTransform x:Name="RightPupilTranslate" X="0" Y="0"/>
						</Ellipse.RenderTransform>
					</Ellipse>
					<!-- Eye highlight -->
					<Ellipse Canvas.Left="10" Canvas.Top="5" Width="5" Height="5" Fill="White"/>
				</Canvas>

				<!-- Closed eyes (for blink, hidden by default) -->
				<Path x:Name="LeftEyeClosed" Canvas.Left="64" Canvas.Top="126"
					  Data="M 0,0 Q 11,-4 22,0" Stroke="#2D2D2D" StrokeThickness="2.5"
					  Opacity="0"/>
				<Path x:Name="RightEyeClosed" Canvas.Left="110" Canvas.Top="126"
					  Data="M 0,0 Q 11,-4 22,0" Stroke="#2D2D2D" StrokeThickness="2.5"
					  Opacity="0"/>

				<!-- Left blush -->
				<Ellipse Canvas.Left="52" Canvas.Top="140" Width="18" Height="9"
						 Fill="#FFB6C1" Opacity="0.45"/>
				<!-- Right blush -->
				<Ellipse Canvas.Left="126" Canvas.Top="140" Width="18" Height="9"
						 Fill="#FFB6C1" Opacity="0.45"/>

				<!-- Worried eyebrows (angled inward-down); shown when a session is waiting on you -->
				<Path x:Name="LeftBrow" Canvas.Left="66" Canvas.Top="107"
					  Data="M 0,5 L 17,0" Stroke="#8B4513" StrokeThickness="2.6"
					  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0"/>
				<Path x:Name="RightBrow" Canvas.Left="117" Canvas.Top="107"
					  Data="M 0,0 L 17,5" Stroke="#8B4513" StrokeThickness="2.6"
					  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0"/>

				<!-- Mouth (happy) -->
				<Path x:Name="HappyMouth" Canvas.Left="85" Canvas.Top="148"
					  Data="M 0,0 Q 14,10 28,0"
					  Stroke="#8B4513" StrokeThickness="2" Fill="Transparent"/>

				<!-- Mouth (worried, small open oval); shown alongside the brows when waiting -->
				<Ellipse x:Name="WorriedMouth" Canvas.Left="94" Canvas.Top="150" Width="12" Height="9"
						 Fill="#7A3B10" Opacity="0"/>

				<!-- Claude sparkle/star on top -->
				<Canvas Canvas.Left="88" Canvas.Top="48" RenderTransformOrigin="0.5,0.5">
					<Canvas.RenderTransform>
						<TransformGroup>
							<ScaleTransform x:Name="SparkleScale" ScaleX="1" ScaleY="1"/>
							<RotateTransform x:Name="SparkleRotate" Angle="0" CenterX="12" CenterY="12"/>
						</TransformGroup>
					</Canvas.RenderTransform>
					<!-- 4-point star -->
					<Path Data="M 12,0 L 14.5,8 L 24,12 L 14.5,16 L 12,24 L 9.5,16 L 0,12 L 9.5,8 Z"
						  Fill="#FFD700" Stroke="#FFA500" StrokeThickness="0.8"/>
					<!-- Small center glow -->
					<Ellipse Canvas.Left="8" Canvas.Top="8" Width="8" Height="8"
							 Fill="#FFFACD" Opacity="0.6"/>
				</Canvas>
			</Canvas>

			<!-- Sleepy "z z z" (floats up near the head during long idle) -->
			<Canvas x:Name="SleepZzz" Canvas.Left="126" Canvas.Top="26" Opacity="0">
				<Canvas.RenderTransform>
					<TranslateTransform x:Name="SleepZzzTranslate" X="0" Y="0"/>
				</Canvas.RenderTransform>
				<TextBlock Canvas.Left="0"  Canvas.Top="18" Text="z" FontSize="11" FontWeight="Bold" Foreground="#8FA6C4"/>
				<TextBlock Canvas.Left="9"  Canvas.Top="8"  Text="z" FontSize="14" FontWeight="Bold" Foreground="#8FA6C4"/>
				<TextBlock Canvas.Left="20" Canvas.Top="-2" Text="z" FontSize="17" FontWeight="Bold" Foreground="#8FA6C4"/>
			</Canvas>

			<!-- Laptop group (hidden by default, shown when working) — sleek silver laptop -->
			<Canvas x:Name="LaptopGroup" Opacity="0">

				<!-- ===== Lid / screen ===== -->
				<!-- Aluminum lid frame -->
				<Rectangle Canvas.Left="47" Canvas.Top="158" Width="106" Height="34"
						   RadiusX="6" RadiusY="6" Stroke="#AEB2B7" StrokeThickness="1">
					<Rectangle.Fill>
						<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
							<GradientStop Color="#F2F3F5" Offset="0"/>
							<GradientStop Color="#D7DADE" Offset="0.5"/>
							<GradientStop Color="#C2C5CA" Offset="1"/>
						</LinearGradientBrush>
					</Rectangle.Fill>
				</Rectangle>

				<!-- Dark bezel -->
				<Rectangle Canvas.Left="51" Canvas.Top="162" Width="98" Height="27"
						   RadiusX="4" RadiusY="4" Fill="#1B1D21" Stroke="#0E0F12" StrokeThickness="0.5"/>

				<!-- Webcam dot -->
				<Ellipse Canvas.Left="99" Canvas.Top="163.4" Width="2" Height="2" Fill="#5A6066"/>

				<!-- Glowing display (animated opacity) -->
				<Rectangle x:Name="ScreenGlow" Canvas.Left="53.5" Canvas.Top="165" Width="93" Height="21"
						   RadiusX="2.5" RadiusY="2.5" Opacity="0.85">
					<Rectangle.Fill>
						<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
							<GradientStop Color="#2E6BFF" Offset="0"/>
							<GradientStop Color="#5AA0FF" Offset="0.5"/>
							<GradientStop Color="#46C7E8" Offset="1"/>
						</LinearGradientBrush>
					</Rectangle.Fill>
				</Rectangle>

				<!-- Code lines on screen -->
				<Rectangle Canvas.Left="58" Canvas.Top="168" Width="34" Height="2.2" RadiusX="1" RadiusY="1" Fill="#D6ECFF" Opacity="0.9"/>
				<Rectangle Canvas.Left="58" Canvas.Top="172.5" Width="52" Height="2.2" RadiusX="1" RadiusY="1" Fill="#FFF3B0" Opacity="0.75"/>
				<Rectangle Canvas.Left="58" Canvas.Top="177" Width="26" Height="2.2" RadiusX="1" RadiusY="1" Fill="#FFC4D6" Opacity="0.75"/>
				<Rectangle Canvas.Left="58" Canvas.Top="181.5" Width="44" Height="2.2" RadiusX="1" RadiusY="1" Fill="#D6ECFF" Opacity="0.6"/>

				<!-- Glossy screen highlight -->
				<Rectangle Canvas.Left="53.5" Canvas.Top="165" Width="93" Height="21" RadiusX="2.5" RadiusY="2.5" Opacity="0.22" IsHitTestVisible="False">
					<Rectangle.Fill>
						<LinearGradientBrush StartPoint="0,0" EndPoint="0.7,1">
							<GradientStop Color="White" Offset="0"/>
							<GradientStop Color="Transparent" Offset="0.5"/>
						</LinearGradientBrush>
					</Rectangle.Fill>
				</Rectangle>

				<!-- ===== Hinge ===== -->
				<Rectangle Canvas.Left="45" Canvas.Top="189.5" Width="110" Height="3.5"
						   RadiusX="1.75" RadiusY="1.75">
					<Rectangle.Fill>
						<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
							<GradientStop Color="#B7BABF" Offset="0"/>
							<GradientStop Color="#9A9DA2" Offset="1"/>
						</LinearGradientBrush>
					</Rectangle.Fill>
				</Rectangle>

				<!-- ===== Deck (keyboard base, perspective) ===== -->
				<!-- Front lip / thickness -->
				<Rectangle Canvas.Left="33" Canvas.Top="201.5" Width="134" Height="6"
						   RadiusX="3" RadiusY="3" Fill="#A7ABB0"/>
				<!-- Top deck surface (trapezoid, wider at front) -->
				<Polygon Points="47,192 153,192 165,203 35,203" Stroke="#AEB2B7" StrokeThickness="1">
					<Polygon.Fill>
						<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
							<GradientStop Color="#EAECEE" Offset="0"/>
							<GradientStop Color="#CCCFD3" Offset="1"/>
						</LinearGradientBrush>
					</Polygon.Fill>
				</Polygon>

				<!-- Keyboard keys (row 1) -->
				<Rectangle Canvas.Left="57"  Canvas.Top="193.6" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="65"  Canvas.Top="193.6" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="73"  Canvas.Top="193.6" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="81"  Canvas.Top="193.6" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="89"  Canvas.Top="193.6" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="97"  Canvas.Top="193.6" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="105" Canvas.Top="193.6" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="113" Canvas.Top="193.6" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="121" Canvas.Top="193.6" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="129" Canvas.Top="193.6" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="137" Canvas.Top="193.6" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<!-- Keyboard keys (row 2) -->
				<Rectangle Canvas.Left="61"  Canvas.Top="196.2" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="69"  Canvas.Top="196.2" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="77"  Canvas.Top="196.2" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="85"  Canvas.Top="196.2" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="93"  Canvas.Top="196.2" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="101" Canvas.Top="196.2" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="109" Canvas.Top="196.2" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="117" Canvas.Top="196.2" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="125" Canvas.Top="196.2" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>
				<Rectangle Canvas.Left="133" Canvas.Top="196.2" Width="5" Height="2.2" RadiusX="0.7" RadiusY="0.7" Fill="#42464C"/>

				<!-- Trackpad -->
				<Rectangle Canvas.Left="86" Canvas.Top="198.6" Width="28" Height="4.2"
						   RadiusX="1.4" RadiusY="1.4" Fill="#DADDE0" Stroke="#B4B7BB" StrokeThickness="0.6"/>
			</Canvas>

			<!-- Status indicator dot (doubles as a pulsing, clickable update badge) -->
			<Ellipse x:Name="StatusDot" Canvas.Left="170" Canvas.Top="10" Width="12" Height="12"
					 Stroke="White" StrokeThickness="1.5" ToolTip="대기 중"
					 RenderTransformOrigin="0.5,0.5" Cursor="Hand"
					 MouseLeftButtonDown="StatusDot_Click">
				<Ellipse.RenderTransform>
					<ScaleTransform x:Name="UpdateBadgeScale" ScaleX="1" ScaleY="1"/>
				</Ellipse.RenderTransform>
				<Ellipse.Fill>
					<SolidColorBrush x:Name="StatusDotFill" Color="#888888"/>
				</Ellipse.Fill>
			</Ellipse>
		</Canvas>

		<!-- ===== Activity badge: shows what tool Claude Code is using (Segoe MDL2 glyph) ===== -->
		<Canvas x:Name="ActivityBadge" Canvas.Left="14" Canvas.Top="62" Opacity="0" RenderTransformOrigin="0.5,0.5">
			<Canvas.RenderTransform>
				<ScaleTransform x:Name="ActivityScale" ScaleX="1" ScaleY="1" CenterX="15" CenterY="15"/>
			</Canvas.RenderTransform>
			<Border Width="30" Height="30" CornerRadius="15"
					Background="{DynamicResource LimbStrokeBrush}" BorderBrush="White" BorderThickness="1.5">
				<Border.Effect>
					<DropShadowEffect Color="#40000000" BlurRadius="6" ShadowDepth="1" Direction="270"/>
				</Border.Effect>
				<TextBlock x:Name="ActivityGlyph" FontFamily="Segoe MDL2 Assets" FontSize="14"
						   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
						   Text="&#xE756;"/>
			</Border>
		</Canvas>

		<!-- ===== Speech bubble (top area, does not bob with the character) ===== -->
		<Canvas x:Name="SpeechBubble" Opacity="0" Cursor="Hand"
				MouseLeftButtonDown="SpeechBubble_Click">
			<Canvas.RenderTransform>
				<ScaleTransform x:Name="BubbleScale" ScaleX="1" ScaleY="1" CenterX="110" CenterY="46"/>
			</Canvas.RenderTransform>

			<!-- Tail (diamond); its top is repositioned in code to hug the bubble's bottom edge -->
			<Rectangle x:Name="BubbleTail" Canvas.Left="103" Canvas.Top="34" Width="14" Height="14"
					   Fill="White" Stroke="#E4E4E7" StrokeThickness="1" RenderTransformOrigin="0.5,0.5">
				<Rectangle.RenderTransform>
					<RotateTransform Angle="45"/>
				</Rectangle.RenderTransform>
			</Rectangle>

			<!-- Bubble body -->
			<Border x:Name="BubbleBorder" Canvas.Left="12" Canvas.Top="6" Width="196"
					Background="White" CornerRadius="13" BorderBrush="#E4E4E7" BorderThickness="1"
					Padding="12,8">
				<Border.Effect>
					<DropShadowEffect Color="#40000000" BlurRadius="12" ShadowDepth="2" Direction="270"/>
				</Border.Effect>
				<TextBlock x:Name="SpeechText" TextWrapping="Wrap" TextAlignment="Center"
						   FontSize="12.5" FontWeight="SemiBold" Foreground="#2D2D2D"
						   FontFamily="Segoe UI, Malgun Gothic, Segoe UI Emoji" Text="안녕하세요!"/>
			</Border>
		</Canvas>
	</Canvas>

	<!-- ===== Session dashboard (HUD): per-session cost/time + total system usage =====
	     A Popup renders as its own top-level window, so it can be larger than the widget
	     and sit beside it. Opened from the status dot / "+N" chip / context menu. -->
	<Popup x:Name="HudPopup" AllowsTransparency="True" StaysOpen="False" Placement="Left"
		   PlacementTarget="{Binding ElementName=MainCanvas}" HorizontalOffset="-4"
		   PopupAnimation="Fade" Closed="HudPopup_Closed">
		<Border Background="White" CornerRadius="12" BorderBrush="#E4E4E7" BorderThickness="1"
				Padding="14,12" Margin="10" Width="286">
			<Border.Effect>
				<DropShadowEffect Color="#50000000" BlurRadius="18" ShadowDepth="2" Direction="270"/>
			</Border.Effect>
			<StackPanel>
				<TextBlock Text="세션 대시보드" FontWeight="Bold" FontSize="13" Foreground="#2D2D2D"
						   Margin="0,0,0,9" FontFamily="Segoe UI, Malgun Gothic"/>
				<StackPanel x:Name="HudRows"/>
				<Border Height="1" Background="#EEEEEE" Margin="0,9,0,8"/>
				<TextBlock x:Name="HudFooter" FontSize="10.5" Foreground="#6B7280" TextWrapping="Wrap"
						   LineHeight="16" FontFamily="Segoe UI, Malgun Gothic"/>
			</StackPanel>
		</Border>
	</Popup>
	</Grid>
</Window>
